DATABASE_URL="file:./dev.db"
SESSION_SECRET="replace-with-at-least-32-random-characters"
# Optional: seed creates admin@local with this password (default: admin-admin-CHANGE)
ADMIN_SEED_PASSWORD="admin-admin-CHANGE"

# Email notifications (optional)
# Used by /api/cron/daily-email?token=...
CRON_TOKEN="replace-with-random-token"
PUBLIC_BASE_URL="http://localhost:3000"

# SMTP (required to actually send emails)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="no-reply@example.com"
