DATABASE_URL="postgresql://postgres:postgres@localhost:5432/training?schema=public"
# Optional but recommended for Prisma (non-pooled direct connection)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/training?schema=public"
SESSION_SECRET="replace-with-at-least-32-random-characters"
# Optional: seed creates admin@example.com with this password (default: admin-admin-CHANGE)
ADMIN_SEED_PASSWORD="admin-admin-CHANGE"

# Email notifications (optional)
# Used by /api/cron/daily-email?token=... (optional when running via Vercel Cron)
CRON_TOKEN="replace-with-random-token"
PUBLIC_BASE_URL="http://localhost:3000"

# SMTP (required to actually send emails)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="no-reply@example.com"
