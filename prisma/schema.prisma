generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  role         String        @default("USER") // USER | ADMIN
  createdAt    DateTime      @default(now())
  profile      UserProfile?
  emailSub     UserEmailSubscription?
  logs         WorkoutLog[]
  calendarDays UserCalendarDay[]
  trainingDays TrainingDayEntry[]
  userPrograms UserProgram[]
  exercises    UserExercise[]
}

model UserProfile {
  id                  String  @id @default(cuid())
  userId              String  @unique
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  levelSelfAssessment String?
  limitations         String?
  pullupsMax          Int?
  squatsMax           Int?
  pushupsMax          Int?
  lungesMax           Int?
  onboardingDone      Boolean @default(false)
}

model Program {
  id           String         @id @default(cuid())
  slug         String         @unique
  name         String
  description  String?
  durationDays Int
  days         ProgramDay[]
  userPrograms UserProgram[]
}

model ProgramDay {
  id          String        @id @default(cuid())
  programId   String
  program     Program       @relation(fields: [programId], references: [id], onDelete: Cascade)
  dayNumber   Int
  title       String
  dayType     String // WORKOUT | REST
  restBodyUk  String?
  exercises   DayExercise[]
  logs        WorkoutLog[]
  post        DailyPost?

  @@unique([programId, dayNumber])
}

model DailyPost {
  id           String     @id @default(cuid())
  slug         String     @unique
  dayNumber    Int?
  block        String // PREPARATION | BASIC | ADVANCED | TURBO | CONCLUSION
  titleUk      String
  bodyUk       String
  imageUrl     String?
  sourceFile   String?
  programDayId String?    @unique
  programDay   ProgramDay? @relation(fields: [programDayId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([dayNumber], map: "dailypost_day_unique")
}

model Exercise {
  id            String        @id @default(cuid())
  slug          String        @unique
  nameUk        String
  descriptionUk String
  dayExercises  DayExercise[]
}

model DayExercise {
  id           String     @id @default(cuid())
  programDayId String
  programDay   ProgramDay @relation(fields: [programDayId], references: [id], onDelete: Cascade)
  exerciseId   String
  exercise     Exercise   @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  sortOrder    Int
  sets         Int
  reps         String
  restSec      Int?
  coachingUk   String?
}

model WorkoutLog {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  programDayId String
  programDay   ProgramDay @relation(fields: [programDayId], references: [id], onDelete: Cascade)
  status       String // DONE | SKIPPED
  notes        String?
  createdAt    DateTime   @default(now())

  @@unique([userId, programDayId])
}

model UserProgram {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId  String
  program    Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  cursorDay  Int      @default(1)
  startedAt  DateTime @default(now())

  @@unique([userId, programId])
}

model UserCalendarDay {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayKey    String   // YYYY-MM-DD
  status    String   // TRAINING | STRETCHING | REST | SICK
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, dayKey])
  @@index([userId, dayKey])
}

model TrainingDayEntry {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayKey     String   // YYYY-MM-DD (matches UserCalendarDay.dayKey)
  mode       String   @default("ROUNDS") // ROUNDS | SETS
  rounds     Int
  pullupsReps Int
  squatsReps  Int
  pushupsReps Int
  lungesReps  Int
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lines      TrainingDayExerciseLine[]

  @@unique([userId, dayKey])
  @@index([userId, dayKey])
}

model UserExercise {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String
  short      String
  metric     String   @default("REPS") // REPS | TIME
  maxReps    Int      @default(5000)
  sortOrder  Int
  builtinKey String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lines      TrainingDayExerciseLine[]

  @@unique([userId, builtinKey])
  @@index([userId, sortOrder])
}

model TrainingDayExerciseLine {
  id                 String           @id @default(cuid())
  trainingDayEntryId String
  trainingDayEntry   TrainingDayEntry @relation(fields: [trainingDayEntryId], references: [id], onDelete: Cascade)
  userExerciseId     String
  userExercise       UserExercise     @relation(fields: [userExerciseId], references: [id], onDelete: Cascade)
  reps               Int
  sortOrder          Int

  @@unique([trainingDayEntryId, userExerciseId])
  @@index([trainingDayEntryId, sortOrder])
}

model UserEmailSubscription {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled       Boolean  @default(false)
  lastSentDayKey String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
